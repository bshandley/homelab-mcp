# ===========================================
# Homelab MCP Server Configuration
# ===========================================

# Transport mode
# - Set PORT to enable HTTP mode (for Claude Chat / remote access)
# - Leave PORT unset for stdio mode (for Claude Desktop / Claude Code)
PORT=3000

# API authentication (required for HTTP mode)
# Generate with: openssl rand -hex 32
API_KEY=your-secure-api-key-here

# Capability level (1-4)
# 1 = Monitor (read-only)
# 2 = Operate (start/stop/restart)
# 3 = Configure (read configs)
# 4 = Manage (write configs, exec)
CAPABILITY_LEVEL=1

# Docker socket path
DOCKER_SOCKET=/var/run/docker.sock

# Dockge stacks path
DOCKGE_STACKS_PATH=/opt/stacks

# OPNsense API credentials (optional)
# Get from: OPNsense UI → System → Access → Users → API keys
OPNSENSE_HOST=10.0.0.1
OPNSENSE_API_KEY=
OPNSENSE_API_SECRET=

# TrueNAS API credentials (optional)
# Get from: TrueNAS UI → Top-right menu → API Keys
TRUENAS_HOST=10.0.0.105
TRUENAS_API_KEY=
